{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Automatically runs ESLint on TypeScript files when saved to maintain code quality",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.ts",
      "*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx eslint --fix --no-warn-ignored"
  }
}