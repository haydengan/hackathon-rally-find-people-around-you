{
  "enabled": true,
  "name": "Run Tests After Task",
  "description": "Automatically runs the test suite after completing a spec task to verify implementation correctness",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "npx vitest run --reporter=verbose"
  }
}